{
  "buildCommand": "npm run build",
  "outputDirectory": "dist"
}
{
  "version": 2,
  "buildCommand": "npm run build -w frontend",
  "outputDirectory": "frontend/dist",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/[...all].js"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/.*",
      "dest": "/index.html"
    }
  ]
}
